@app.route("/my_diet")
def my_diet():
    if "member_id" not in session:
        return redirect("/login")
    
    conn = get_db()
    diet = conn.execute("""
        SELECT dp.* 
        FROM diet_plans dp
        JOIN member_diet_plans mdp ON dp.id = mdp.diet_plan_id
        WHERE mdp.member_id = ?
    """, (session["member_id"],)).fetchone()
    conn.close()
    return render_template("my_diet.html", diet=diet)

