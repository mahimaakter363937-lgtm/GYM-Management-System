{% extends "base.html" %}
{% block title %}My Diet Plan - Gym Management{% endblock %}
{% block content %}
<div class="page-wrapper">
  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
    <h1>🥗 My Diet Plan</h1>
    <span class="pill pill-success">Goal: {{ diet['fitness_goal'] if diet else 'Not Assigned' }}</span>
  </div>

  {% if diet %}
  <div class="card" style="border-top: 4px solid var(--primary-color);">
    <h3 style="color:var(--primary-color); display:flex; align-items:center; gap:0.5rem;">
      <span>🥣</span> {{ diet['name'] }}
    </h3>
    <hr style="border:0; border-top:1px solid var(--card-border); margin:1.5rem 0;">
    
    <div style="white-space: pre-wrap; font-size:1.1rem; line-height:1.8; color:var(--text-main); background-color:rgba(0,0,0,0.02); padding:2rem; border-radius:12px; border:1px solid var(--card-border);">{{ diet['description'] }}</div>
    
    <div class="mt-4 text-center">
      <p class="text-muted">Follow this plan for best results! 💪</p>
    </div>
  </div>
  {% else %}
  <div class="card text-center" style="padding:4rem;">
    <div class="nav-icon" style="font-size:4rem;">🥗</div>
    <h2 class="mt-3">Diet Plan Not Assigned</h2>
    <p class="text-muted" style="font-size:1.1rem; max-width:600px; margin:1rem auto;">Your personalized diet plan has not been assigned yet. Please contact the admin or your trainer to get your diet plan updated!</p>
    <a href="/dashboard" class="btn btn-primary mt-4">Back to Dashboard</a>
  </div>
  {% endif %}
</div>
{% endblock %}

